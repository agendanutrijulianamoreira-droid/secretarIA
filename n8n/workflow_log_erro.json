{
  "name": "SecretarIA — Log de Erro (Sub-Workflow)",
  "nodes": [

    {
      "parameters": {
        "inputSource": "passthrough"
      },
      "id": "le-0001",
      "name": "Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [0, 300]
    },

    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/workflow_erros",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "user_id":       "={{ $json.user_id ?? null }}",
          "workflow_nome": "={{ $json.workflow_nome ?? 'desconhecido' }}",
          "execucao_id":   "={{ $json.execucao_id ?? null }}",
          "node_nome":     "={{ $json.node_nome ?? null }}",
          "mensagem_erro": "={{ $json.mensagem_erro ?? $json.error ?? 'Erro sem descrição' }}",
          "stack_trace":   "={{ $json.stack_trace ?? null }}",
          "payload":       "={{ $json.payload ? JSON.stringify($json.payload).substring(0, 5000) : null }}"
        },
        "options": {}
      },
      "id": "le-0002",
      "name": "Salvar Erro no Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 300]
    }

  ],
  "connections": {
    "Trigger": {
      "main": [[{ "node": "Salvar Erro no Supabase", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "staticData": null,
  "meta": { "templateId": "secretaria-log-erro-001" }
}
