{
  "name": "SecretarIA Nutri Juliana — Follow-up Automático",
  "nodes": [

    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "hours", "hoursInterval": 6 }
          ]
        }
      },
      "id": "node-trigger-cron",
      "name": "Cron 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-1200, 800]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/profiles",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "wa_conectado", "value": "eq.true" },
            { "name": "onboarding_completo", "value": "eq.true" }
          ]
        },
        "options": {}
      },
      "id": "node-list-profiles",
      "name": "Listar Perfis Ativos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-1000, 800]
    },
    {
      "parameters": {
        "options": {
          "batchSize": 1
        }
      },
      "id": "node-loop-profiles",
      "name": "Loop de Perfis",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [-800, 800]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/rpc/get_tenant_config",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ p_user_id: $json.id }) }}",
        "options": {}
      },
      "id": "node-get-tenant-config",
      "name": "Buscar Config Tenant",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-600, 800]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/rpc/get_eligible_followups",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ p_user_id: $('Loop de Perfis').item.json.id, p_limit: 20 }) }}",
        "options": {}
      },
      "id": "node-get-eligible-contacts",
      "name": "Buscar Contatos Followup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-400, 800]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [
            {
              "id": "cond-has-contacts",
              "leftValue": "={{ $json.length }}",
              "rightValue": 0,
              "operator": { "type": "number", "operation": "greater" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "node-if-has-contacts",
      "name": "Tem Contatos?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [-200, 800]
    },

    {
      "parameters": { "options": {} },
      "id": "fb000004-0000-0000-0000-000000000004",
      "name": "Loop Contatos",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [-80, 800]
    },

    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "fc1", "leftValue": "={{ $json.followup_count }}", "rightValue": 0, "operator": { "type": "number", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "FU_1"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "fc2", "leftValue": "={{ $json.followup_count }}", "rightValue": 1, "operator": { "type": "number", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "FU_2"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "fc3", "leftValue": "={{ $json.followup_count }}", "rightValue": 2, "operator": { "type": "number", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "FU_3_FINAL"
            }
          ]
        },
        "options": {}
      },
      "id": "fb000005-0000-0000-0000-000000000005",
      "name": "Switch Qual FollowUp",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [160, 800]
    },

    {
      "parameters": {
        "promptType": "define",
        "text": "=Gere uma mensagem de follow-up personalizada para: Nome: {{ $json.nome || 'nossa lead' }}, Queixa principal: {{ $json.principal_queixa || 'não informada' }}, Número do follow-up: 1 (D+3 após primeiro contato). Template base: {{ $('Buscar Config Tenant').first().json.followup_template_1 }}",
        "options": {
          "systemMessage": "=Você é a {{ $('Buscar Config Tenant').first().json.nome_assistente }}, assistente do consultório da {{ $('Buscar Config Tenant').first().json.nome_profissional }}.\n\nGere uma mensagem de follow-up CURTA e NATURAL para uma lead que não respondeu.\n\nDiretrizes:\n- Tom {{ $('Buscar Config Tenant').first().json.tom_voz }}, feminino, sem pressão\n- Mencione a queixa se disponível\n- Use o nome da pessoa\n- Siga o estilo do template base\n- Máximo 3 parágrafos curtos\n\nRetorne apenas o texto da mensagem."
        }
      },
      "id": "node-ai-fu1",
      "name": "Gerar FU1",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [400, 640]
    },

    {
      "parameters": {
        "promptType": "define",
        "text": "=Gere uma mensagem de follow-up personalizada para: Nome: {{ $json.nome || 'nossa lead' }}, Queixa principal: {{ $json.principal_queixa || 'não informada' }}, Número do follow-up: 2. Template base: {{ $('Buscar Config Tenant').first().json.followup_template_2 }}",
        "options": {
          "systemMessage": "=Você é a {{ $('Buscar Config Tenant').first().json.nome_assistente }}, assistente do consultório da {{ $('Buscar Config Tenant').first().json.nome_profissional }}.\n\nGere uma mensagem de follow-up CURTA e NATURAL.\n\nDiretrizes:\n- Tom {{ $('Buscar Config Tenant').first().json.tom_voz }}, feminino, sem pressão\n- Use o nome da pessoa\n- Siga o estilo do template base\n\nRetorne apenas o texto da mensagem."
        }
      },
      "id": "node-ai-fu2",
      "name": "Gerar FU2",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [400, 800]
    },

    {
      "parameters": {
        "promptType": "define",
        "text": "=Gere uma mensagem de follow-up FINAL personalizada para: Nome: {{ $json.nome || 'nossa lead' }}, Queixa principal: {{ $json.principal_queixa || 'não informada' }}, Número do follow-up: 3. Template base: {{ $('Buscar Config Tenant').first().json.followup_template_3 }}",
        "options": {
          "systemMessage": "=Você é a {{ $('Buscar Config Tenant').first().json.nome_assistente }}, assistente do consultório da {{ $('Buscar Config Tenant').first().json.nome_profissional }}.\n\nEsta é a ÚLTIMA mensagem de contato.\n\nDiretrizes:\n- Tom {{ $('Buscar Config Tenant').first().json.tom_voz }}, feminino, sem pressão\n- Use o nome da pessoa\n- Deixe claro que é o último contato por enquanto\n- Siga o estilo do template base\n\nRetorne apenas o texto da mensagem."
        }
      },
      "id": "node-ai-fu3",
      "name": "Gerar FU3 Final",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [400, 960]
    },

    {
      "parameters": {
        "model": "gpt-4.1-mini",
        "options": {}
      },
      "id": "fb000009-0000-0000-0000-000000000009",
      "name": "OpenAI FU1",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [400, 440]
    },

    {
      "parameters": {
        "model": "gpt-4.1-mini",
        "options": {}
      },
      "id": "fb000010-0000-0000-0000-000000000010",
      "name": "OpenAI FU2",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [400, 600]
    },

    {
      "parameters": {
        "model": "gpt-4.1-mini",
        "options": {}
      },
      "id": "fb000011-0000-0000-0000-000000000011",
      "name": "OpenAI FU3",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1,
      "position": [400, 760]
    },

    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "mf1",
              "name": "mensagem_followup",
              "value": "={{ $json.text }}",
              "type": "string"
            },
            {
              "id": "mf2",
              "name": "phone_destino",
              "value": "={{ $('Loop Contatos').item.json.phone }}",
              "type": "string"
            },
            {
              "id": "mf3",
              "name": "followup_count_atual",
              "value": "={{ $('Loop Contatos').item.json.followup_count || 0 }}",
              "type": "number"
            },
            {
              "id": "mf4",
              "name": "contato_id",
              "value": "={{ $('Loop Contatos').item.json.id }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "fb000012-0000-0000-0000-000000000012",
      "name": "Merge FU1",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 640]
    },

    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "mf5", "name": "mensagem_followup", "value": "={{ $json.text }}", "type": "string" },
            { "id": "mf6", "name": "phone_destino", "value": "={{ $('Loop Contatos').item.json.phone }}", "type": "string" },
            { "id": "mf7", "name": "followup_count_atual", "value": "={{ $('Loop Contatos').item.json.followup_count || 0 }}", "type": "number" },
            { "id": "mf8", "name": "contato_id", "value": "={{ $('Loop Contatos').item.json.id }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "fb000013-0000-0000-0000-000000000013",
      "name": "Merge FU2",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 800]
    },

    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "mf9", "name": "mensagem_followup", "value": "={{ $json.text }}", "type": "string" },
            { "id": "mf10", "name": "phone_destino", "value": "={{ $('Loop Contatos').item.json.phone }}", "type": "string" },
            { "id": "mf11", "name": "followup_count_atual", "value": "={{ $('Loop Contatos').item.json.followup_count || 0 }}", "type": "number" },
            { "id": "mf12", "name": "contato_id", "value": "={{ $('Loop Contatos').item.json.id }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "fb000014-0000-0000-0000-000000000014",
      "name": "Merge FU3",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 960]
    },

    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $('Buscar Config Tenant').first().json.wa_phone_number_id }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $('Buscar Config Tenant').first().json.wa_access_token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ messaging_product: 'whatsapp', recipient_type: 'individual', to: $json.phone_destino, type: 'text', text: { preview_url: false, body: $json.mensagem_followup } }) }}",
        "options": {}
      },
      "id": "node-send-whatsapp",
      "name": "Enviar FollowUp (Meta)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 800]
    },

    {
      "parameters": {
        "jsCode": "const item = $input.item;\nconst count = item.json.followup_count_atual;\nconst config = {\n  1: 7,   // FU1 foi hoje (count=0→1), próximo em 7 dias\n  2: 7,   // FU2 foi hoje (count=1→2), próximo em 7 dias  \n  3: 9999 // FU3 foi hoje (count=2→3), não há mais follow-up\n};\n\nconst diasProximo = config[count + 1] || 9999;\nconst novoProximo = diasProximo < 9999 \n  ? new Date(Date.now() + diasProximo * 86400000).toISOString()\n  : null;\n\nconst novoStatus = (count + 1 >= 3) ? 'INATIVO' : item.json.status;\n\nreturn [{\n  json: {\n    ...item.json,\n    novo_followup_count: count + 1,\n    novo_proximo_followup: novoProximo,\n    novo_status: novoStatus\n  }\n}];"
      },
      "id": "fb000016-0000-0000-0000-000000000016",
      "name": "Calcular Proximo FU",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 800]
    },

    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/contatos",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "user_id", "value": "=eq.{{ $('Loop de Perfis').item.json.id }}" },
            { "name": "phone", "value": "=eq.{{ $json.phone_destino }}" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ followup_count: $json.novo_followup_count, ultimo_followup: new Date().toISOString(), proximo_followup: $json.novo_proximo_followup, status: $json.novo_status, etiqueta: ($json.novo_status === 'INATIVO' ? 'INATIVO_30D' : 'FOLLOW_UP_PENDENTE') }) }}",
        "options": {}
      },
      "id": "node-update-supabase-fu",
      "name": "Atualizar Supabase FU",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 800]
    },

    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/historico_conversas",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ phone: $json.phone_destino, role: 'assistant', content: $json.mensagem_followup, tipo_midia: 'texto', agente: 'followup' }) }}",
        "options": {}
      },
      "id": "node-save-fu-history",
      "name": "Salvar FU no Histórico",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 800]
    },

    {
      "parameters": { "amount": 10 },
      "id": "fb000019-0000-0000-0000-000000000019",
      "name": "Wait 10s Entre Contatos",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [1640, 800],
      "webhookId": "nutri-fu-wait"
    }

  ],

  "connections": {
    "Cron 6h": { "main": [[{ "node": "Listar Perfis Ativos", "type": "main", "index": 0 }]] },
    "Listar Perfis Ativos": { "main": [[{ "node": "Loop de Perfis", "type": "main", "index": 0 }]] },
    "Loop de Perfis": { "main": [[{ "node": "Buscar Config Tenant", "type": "main", "index": 0 }], []] },
    "Buscar Config Tenant": { "main": [[{ "node": "Buscar Contatos Followup", "type": "main", "index": 0 }]] },
    "Buscar Contatos Followup": { "main": [[{ "node": "Tem Contatos?", "type": "main", "index": 0 }]] },
    "Tem Contatos?": { "main": [[{ "node": "Loop Contatos", "type": "main", "index": 0 }], [{ "node": "Loop de Perfis", "type": "main", "index": 0 }]] },
    "Loop Contatos": { "main": [[{ "node": "Switch Qual FollowUp", "type": "main", "index": 0 }], [{ "node": "Loop de Perfis", "type": "main", "index": 0 }]] },
    "Switch Qual FollowUp": { "main": [[{ "node": "Gerar FU1", "type": "main", "index": 0 }], [{ "node": "Gerar FU2", "type": "main", "index": 0 }], [{ "node": "Gerar FU3 Final", "type": "main", "index": 0 }]] },
    "Gerar FU1": { "main": [[{ "node": "Normalizar FU", "type": "main", "index": 0 }]] },
    "Gerar FU2": { "main": [[{ "node": "Normalizar FU", "type": "main", "index": 0 }]] },
    "Gerar FU3 Final": { "main": [[{ "node": "Normalizar FU", "type": "main", "index": 0 }]] },
    "Normalizar FU": { "main": [[{ "node": "Enviar FollowUp (Meta)", "type": "main", "index": 0 }]] },
    "Enviar FollowUp (Meta)": { "main": [[{ "node": "Calcular Próximo Followup", "type": "main", "index": 0 }]] },
    "Calcular Próximo Followup": { "main": [[{ "node": "Atualizar Supabase FU", "type": "main", "index": 0 }]] },
    "Atualizar Supabase FU": { "main": [[{ "node": "Salvar FU no Histórico", "type": "main", "index": 0 }]] },
    "Salvar FU no Histórico": { "main": [[{ "node": "Loop Contatos", "type": "main", "index": 0 }]] }
  },

  "pinData": {},
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  },
  "staticData": null,
  "tags": [],
  "triggerCount": 1,
  "meta": {
    "instanceId": "nutri-juliana-followup"
  }
}
