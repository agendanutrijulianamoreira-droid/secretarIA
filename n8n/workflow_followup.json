        "remoteJid": "={{ $json.phone_destino }}",
        "messageText": "={{ $json.mensagem_followup }}",
        "options_message": { "delay": 3000, "linkPreview": false }
      },
      "id": "fb000015-0000-0000-0000-000000000015",
      "name": "Enviar FollowUp",
      "type": "n8n-nodes-evolution-api.evolutionApi",
      "typeVersion": 1,
      "position": [920, 800],
      "credentials": { "evolutionApi": { "id": "KHvWRbASZNRfzD3a", "name": "EVOLUTION API" } }
    },

    {
      "parameters": {
        "jsCode": "const item = $input.item;\nconst count = item.json.followup_count_atual;\nconst config = {\n  1: 7,   // FU1 foi hoje (count=0→1), próximo em 7 dias\n  2: 7,   // FU2 foi hoje (count=1→2), próximo em 7 dias  \n  3: 9999 // FU3 foi hoje (count=2→3), não há mais follow-up\n};\n\nconst diasProximo = config[count + 1] || 9999;\nconst novoProximo = diasProximo < 9999 \n  ? new Date(Date.now() + diasProximo * 86400000).toISOString()\n  : null;\n\nconst novoStatus = (count + 1 >= 3) ? 'INATIVO' : item.json.status;\n\nreturn [{\n  json: {\n    ...item.json,\n    novo_followup_count: count + 1,\n    novo_proximo_followup: novoProximo,\n    novo_status: novoStatus\n  }\n}];"
      },
      "id": "fb000016-0000-0000-0000-000000000016",
      "name": "Calcular Proximo FU",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 800]
    },

    {
      "parameters": {
        "operation": "update",
        "tableId": "contatos",
        "filters": { "conditions": [{ "keyName": "phone", "condition": "eq", "keyValue": "={{ $json.phone_destino }}" }] },
        "fieldsUi": {
          "fieldValues": [
            { "fieldId": "followup_count", "fieldValue": "={{ $json.novo_followup_count }}" },
            { "fieldId": "ultimo_followup", "fieldValue": "={{ $now }}" },
            { "fieldId": "proximo_followup", "fieldValue": "={{ $json.novo_proximo_followup }}" },
            { "fieldId": "status", "fieldValue": "={{ $json.novo_status }}" },
            { "fieldId": "etiqueta", "fieldValue": "={{ $json.novo_status === 'INATIVO' ? 'INATIVO_30D' : 'FOLLOW_UP_PENDENTE' }}" }
          ]
        }
      },
      "id": "fb000017-0000-0000-0000-000000000017",
      "name": "Atualizar Supabase FU",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1400, 800],
      "credentials": { "supabaseApi": { "id": "NeuU5JBhqto8WxIv", "name": "Teste" } }
