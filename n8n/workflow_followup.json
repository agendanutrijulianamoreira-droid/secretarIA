      "id": "fb000001-0000-0000-0000-000000000001",
      "name": "Cron 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [-800, 800]
    },

    {
      "parameters": {
        "operation": "getAll",
        "tableId": "contatos",
        "filters": {
          "conditions": [
            { "keyName": "ia_pausada", "condition": "eq", "keyValue": "false" },
            { "keyName": "lgpd_consent", "condition": "eq", "keyValue": "true" }
          ]
        },
        "options": { "limit": 50 }
      },
      "id": "fb000002-0000-0000-0000-000000000002",
      "name": "Buscar Elegíveis Followup",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [-560, 800],
      "credentials": { "supabaseApi": { "id": "NeuU5JBhqto8WxIv", "name": "Teste" } }
    },

    {
      "parameters": {
        "jsCode": "const agora = new Date();\nconst itens = $input.all();\n\n// Filtra apenas contatos elegíveis para follow-up:\n// - proximo_followup <= agora\n// - status em LEAD ou AGENDADO\n// - followup_count < 3\nconst elegiveis = itens.filter(item => {\n  const c = item.json;\n  if (!c.proximo_followup) return false;\n  const proximo = new Date(c.proximo_followup);\n  return (\n    proximo <= agora &&\n    ['LEAD', 'AGENDADO'].includes(c.status) &&\n    (c.followup_count || 0) < 3\n  );\n});\n\nreturn elegiveis;"
      },
      "id": "fb000003-0000-0000-0000-000000000003",
      "name": "Filtrar Elegíveis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-320, 800]
    },

    {
      "parameters": { "options": {} },
      "id": "fb000004-0000-0000-0000-000000000004",
      "name": "Loop Contatos",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [-80, 800]
    },

    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "fc1", "leftValue": "={{ $json.followup_count }}", "rightValue": 0, "operator": { "type": "number", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "FU_1"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "fc2", "leftValue": "={{ $json.followup_count }}", "rightValue": 1, "operator": { "type": "number", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "FU_2"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [{ "id": "fc3", "leftValue": "={{ $json.followup_count }}", "rightValue": 2, "operator": { "type": "number", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true, "outputKey": "FU_3_FINAL"
            }
          ]
        },
        "options": {}
      },
      "id": "fb000005-0000-0000-0000-000000000005",
      "name": "Switch Qual FollowUp",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [160, 800]
    },

    {
      "parameters": {
        "promptType": "define",
        "text": "=Gere uma mensagem de follow-up personalizada para: Nome: {{ $json.nome || 'nossa lead' }}, Queixa principal: {{ $json.principal_queixa || 'não informada' }}, Número do follow-up: 1 (D+3 após primeiro contato).",
        "options": {
          "systemMessage": "Você é a Lívia, assistente do consultório da Nutri Juliana.\n\nGere uma mensagem de follow-up CURTA e NATURAL (máximo 3 parágrafos curtos) para uma lead que não respondeu após o primeiro contato.\n\nDiretrizes:\n- Tom acolhedor, feminino, sem pressão\n- Mencione a queixa da pessoa de forma natural se disponível\n- Convide para agendar uma avaliação\n- Sem emojis excessivos\n- Nunca mencione preços\n- Use o nome da pessoa\n- Máximo 200 caracteres por parágrafo\n\nRetorne apenas o texto da mensagem, sem aspas, sem prefixos."
        }
      },
      "id": "fb000006-0000-0000-0000-000000000006",
      "name": "Gerar FU1",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [400, 640]
    },

    {
      "parameters": {
        "promptType": "define",
        "text": "=Gere uma mensagem de follow-up personalizada para: Nome: {{ $json.nome || 'nossa lead' }}, Queixa principal: {{ $json.principal_queixa || 'não informada' }}, Número do follow-up: 2 (D+7).",
        "options": {
          "systemMessage": "Você é a Lívia, assistente do consultório da Nutri Juliana.\n\nGere uma mensagem de follow-up CURTA e NATURAL (máximo 3 parágrafos curtos) para uma lead que não respondeu no 2º contato.\n\nDiretrizes:\n- Tom mais suave, sem insistência\n- Reforce que a porta está aberta\n- Mencione brevemente o impacto do acompanhamento nutricional no dia a dia\n- Sem emojis excessivos\n- Nunca mencione preços\n- Use o nome da pessoa\n- Máximo 200 caracteres por parágrafo\n\nRetorne apenas o texto da mensagem, sem aspas."
        }
      },
      "id": "fb000007-0000-0000-0000-000000000007",
      "name": "Gerar FU2",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [400, 800]
    },

    {
      "parameters": {
        "promptType": "define",
        "text": "=Gere uma mensagem de follow-up personalizada para: Nome: {{ $json.nome || 'nossa lead' }}, Queixa principal: {{ $json.principal_queixa || 'não informada' }}, Número do follow-up: 3 (FINAL — D+14).",
        "options": {
          "systemMessage": "Você é a Lívia, assistente do consultório da Nutri Juliana.\n\nGere uma mensagem de follow-up FINAL e GENTIL para uma lead que não respondeu após 2 tentativas. Este é o último contato.\n\nDiretrizes:\n- Tom de cuidado genuíno, sem mágoa ou pressão\n- Informe que este é o último contato por enquanto\n- Deixe a porta aberta para quando ela estiver pronta\n- Use 💛 no final (único emoji permitido)\n- Nunca mencione preços\n- Use o nome da pessoa\n- Máximo 200 caracteres por parágrafo\n\nRetorne apenas o texto da mensagem, sem aspas."
        }
      },
      "id": "fb000008-0000-0000-0000-000000000008",
      "name": "Gerar FU3 Final",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
