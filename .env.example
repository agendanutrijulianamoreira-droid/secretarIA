# =============================================================================
# SECRETARIA IA — NUTRI JULIANA
# Arquivo .env.example — Copie para .env e preencha os valores
# NUNCA commite o .env com valores reais
# =============================================================================

# -----------------------------------------------------------------------------
# EVOLUTION API (WhatsApp)
# -----------------------------------------------------------------------------
EVO_BASE_URL=https://seu-servidor-evo.com
EVO_API_KEY=sua_chave_evo_api
EVO_INSTANCE_NAME=nutri-juliana       # Nome da instância no Evolution API

# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# SUPABASE
# Use SEMPRE a service_role_key no n8n (nunca a anon_key para dados sensíveis)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://seuprojectoaqui.supabase.co
SUPABASE_ANON_KEY=eyJ...              # Apenas para o App React (leitura autenticada)
SUPABASE_SERVICE_KEY=eyJ...           # Para o n8n e backend (acesso total)

# -----------------------------------------------------------------------------
# POSTGRESQL (memória de conversas)
# Pode ser o mesmo banco do Supabase ou um Postgres separado
# -----------------------------------------------------------------------------
POSTGRES_HOST=db.seuprojectoaqui.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_postgres

# -----------------------------------------------------------------------------
# REDIS (deduplicação e buffer de mensagens picotadas)
# -----------------------------------------------------------------------------
REDIS_HOST=seu-redis.upstash.io       # Upstash Redis (gratuito no início)
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_redis
REDIS_TLS=true                        # true para Upstash, false para Redis local

# -----------------------------------------------------------------------------
# APP REACT (variáveis públicas — prefixo VITE_)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://seuprojectoaqui.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_APP_NAME=SecretarIA Nutri Juliana

# -----------------------------------------------------------------------------
# N8N
# -----------------------------------------------------------------------------
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/nutri-juliana
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=sua_senha_n8n

# =============================================================================
# CREDENCIAIS NO N8N — IDs das credenciais configuradas
# (Preencher após configurar as credenciais no painel do n8n)
# =============================================================================
