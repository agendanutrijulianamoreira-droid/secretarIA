rules_version = '2';

// ──────────────────────────────────────────────────────────────────────────────
//  SecretarIA — Firestore Security Rules (Isolamento Estrito Zero Trust)
// ──────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções de Autorização ──────────────────────────────────────────────

    // E-mail fixo da administradora do sistema
    function isAdmin() {
      return request.auth != null 
          && request.auth.token.email == "agendanutrijulianamoreira@gmail.com";
    }

    // Usuário autenticado qualquer
    function isAuth() {
      return request.auth != null;
    }

    // Verifica se o usuário é o dono do cliente baseado no e-mail do documento
    function isClientOwner(clientData) {
      return isAuth() && clientData.email == request.auth.token.email;
    }

    // Verifica se o usuário é o dono do cliente pai buscando o documento original
    // Nota: Necessário para sub-coleções que não replicam o e-mail em cada doc.
    function verifyParentOwner(clientId) {
      return isAuth() && get(/databases/$(database)/documents/clients/$(clientId)).data.email == request.auth.token.email;
    }

    // ── Coleção /clients ────────────────────────────────────────────────────

    match /clients/{clientId} {
      // Clientes só podem ler seu próprio documento. 
      // O 'list' (query) só funcionará se houver filtro por email.
      allow read: if isAdmin() || isClientOwner(resource.data);
      
      // Apenas Admin cria ou deleta contas.
      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      // Update permitido apenas para Admin ou o próprio dono.
      allow update: if isAdmin() || isClientOwner(resource.data);

      // ── Sub-coleções Hierárquicas ──────────────────────────────────────────
      // (mensagens, leads, pacientes, serviços, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if isAdmin() || verifyParentOwner(clientId);
      }

      // Restrições específicas de escrita para Invoices (Faturas)
      match /invoices/{docId} {
        allow read: if isAdmin() || verifyParentOwner(clientId);
        allow create, update, delete: if isAdmin();
      }
    }

    // ── Outras Coleções ─────────────────────────────────────────────────────

    // Alertas globais de sistema: Apenas Admin
    match /alerts/{alertId} {
      allow read, write: if isAdmin();
    }

    // Tokens de API: Apenas Admin escreve, dono do cliente lê
    match /tokens/{clientId} {
      allow read: if isAdmin() || verifyParentOwner(clientId);
      allow write: if isAdmin();
    }

    // Status de Fluxos: Apenas Admin escreve, dono do cliente lê
    match /n8n_fluxos/{clientId} {
      allow read: if isAdmin() || verifyParentOwner(clientId);
      allow write: if isAdmin();
    }

    // ── Bloqueio total (Fallback) ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}