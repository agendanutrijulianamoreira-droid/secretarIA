rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin pode ler/escrever tudo
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.role == 'admin';
    }
    // Cliente pode ler seu próprio documento
    match /clients/{clientId} {
      allow read: if request.auth != null && request.auth.token.client_id == clientId;
    }
    match /clients/{clientId}/{sub=**} {
      allow read: if request.auth != null && request.auth.token.client_id == clientId;
      allow write: if request.auth != null && request.auth.token.client_id == clientId && sub == 'messages';
    }
  }
}